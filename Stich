        // Toggle mobile menu logic (concept)
        document.querySelector('header button.material-symbols-outlined').addEventListener('click', () => {
            const sidebar = document.querySelector('aside');
            if (sidebar.classList.contains('hidden')) {
                sidebar.classList.remove('hidden');
                sidebar.classList.add('fixed', 'left-0', 'top-14', 'h-[calc(100vh-56px)]', 'z-50', 'w-full', 'max-w-[280px]', 'animate-in', 'slide-in-from-left');
            } else if (sidebar.classList.contains('fixed')) {
                sidebar.classList.add('hidden');
                sidebar.classList.remove('fixed', 'left-0', 'top-14', 'h-[calc(100vh-56px)]', 'z-50', 'w-full', 'max-w-[280px]');
            }
        });
